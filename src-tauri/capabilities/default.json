{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-closable",
    "opener:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://sessionserver.mojang.com/*"
        },
        {
          "url": "https://api.mojang.com/*"
        }
      ]
    }
  ]
}